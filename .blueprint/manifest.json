{
  "name": "AiRepoBlueprint",
  "version": "1.3.0",
  "description": "Reusable template-driven AI configuration blueprint for software repositories.",
  "templateRoot": "templates",
  "toolsPath": ".blueprint/tools.json",
  "ownershipPath": ".blueprint/ownership.json",
  "schemaPath": ".blueprint/schema.json",
  "canonicalDocsPath": "docs/ai",
  "defaults": {
    "ProjectName": "NewProject",
    "ProjectType": "application",
    "PrimaryLanguage": "unspecified",
    "Framework": "unspecified",
    "PackageManager": "unspecified",
    "InstallCommand": "unspecified",
    "TestCommand": "unspecified",
    "LintCommand": "unspecified",
    "BuildCommand": "unspecified",
    "RunCommand": "unspecified",
    "DeploymentTarget": "unspecified",
    "ReviewPolicy": "Human review required before merging or deploying meaningful changes."
  },
  "generatedFiles": [
    ".blueprint/applied.json"
  ],
  "sharedFolders": [
    { "path": ".blueprint", "ownership": "generated" },
    { "path": "docs", "ownership": "customizable" },
    { "path": "docs/ai", "ownership": "customizable" }
  ],
  "sharedFiles": [
    { "source": "shared/README.md", "target": "README.md", "render": true, "ownership": "customizable" },
    { "source": "shared/CHANGELOG.md", "target": "CHANGELOG.md", "render": true, "ownership": "customizable" },
    { "source": "shared/.blueprint/README.md", "target": ".blueprint/README.md", "render": true, "ownership": "generated" },
    { "source": "shared/.blueprint/version.txt", "target": ".blueprint/version.txt", "render": true, "ownership": "generated" },
    { "source": "shared/docs/ai/instructions.md", "target": "docs/ai/instructions.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/context.md", "target": "docs/ai/context.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/conventions.md", "target": "docs/ai/conventions.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/workflows.md", "target": "docs/ai/workflows.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/testing.md", "target": "docs/ai/testing.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/security.md", "target": "docs/ai/security.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/architecture.md", "target": "docs/ai/architecture.md", "render": true, "ownership": "customizable" },
    { "source": "shared/docs/ai/changelog.md", "target": "docs/ai/changelog.md", "render": true, "ownership": "customizable" }
  ],
  "blueprintFolders": [
    ".blueprint",
    "scripts",
    "templates",
    "templates/shared",
    "templates/tools"
  ],
  "blueprintFiles": [
    ".blueprint/manifest.json",
    ".blueprint/ownership.json",
    ".blueprint/tools.json",
    ".blueprint/README.md",
    ".blueprint/schema.json",
    ".blueprint/version.txt",
    "scripts/Blueprint.Common.ps1",
    "scripts/apply-blueprint.ps1",
    "scripts/diff-blueprint.ps1",
    "scripts/update-blueprint.ps1",
    "scripts/validate-blueprint.ps1"
  ]
}
