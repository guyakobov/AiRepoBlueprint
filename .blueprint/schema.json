{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "AiRepoBlueprint manifest",
  "type": "object",
  "required": ["name", "version", "templateRoot", "toolsPath", "defaults", "sharedFolders", "sharedFiles"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "templateRoot": { "type": "string" },
    "toolsPath": { "type": "string" },
    "ownershipPath": { "type": "string" },
    "schemaPath": { "type": "string" },
    "canonicalDocsPath": { "type": "string" },
    "defaults": { "type": "object" },
    "generatedFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sharedFolders": {
      "type": "array",
      "items": { "$ref": "#/definitions/folder" }
    },
    "sharedFiles": {
      "type": "array",
      "items": { "$ref": "#/definitions/file" }
    },
    "blueprintFolders": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blueprintFiles": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "folder": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "ownership": { "type": "string" }
      }
    },
    "file": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "render": { "type": "boolean" },
        "ownership": { "type": "string" }
      }
    }
  }
}
